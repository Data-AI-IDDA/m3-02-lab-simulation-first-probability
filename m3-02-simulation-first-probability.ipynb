#%% md
### Task 1: Estimate π with Monte Carlo

The idea is simple: inscribe a circle of radius 1 inside a 2×2 square. If you throw random darts uniformly at the square, the fraction that land inside the circle should approximate π/4.
#%%
# 1. Generate N = 100,000 random (x, y) points
N = 100000
x = np.random.uniform(-1, 1, N)
y = np.random.uniform(-1, 1, N)

# 2. Classify each point as "inside" (x² + y² ≤ 1) or "outside" the unit circle.
inside_mask = x**2 + y**2 <= 1

# 3. Estimate π as 4 × (points inside) / N.
pi_estimate = 4 * np.sum(inside_mask) / N

# 4. Print your estimate alongside the true value of π.
print(f"Estimated π: {pi_estimate}")
print(f"True π:      {np.pi}")

# 5. Create a scatter plot of the first 5,000 points
N_plot = 5000
plt.figure(figsize=(8, 8))
plt.scatter(x[:N_plot][inside_mask[:N_plot]], y[:N_plot][inside_mask[:N_plot]], color='blue', s=1, label='Inside')
plt.scatter(x[:N_plot][~inside_mask[:N_plot]], y[:N_plot][~inside_mask[:N_plot]], color='red', s=1, label='Outside')

# Draw the unit circle on top for reference
circle = plt.Circle((0, 0), 1, color='black', fill=False, linewidth=2)
plt.gca().add_patch(circle)

plt.axis('equal')
plt.title(f"Monte Carlo Simulation (First {N_plot} points)")
plt.legend()
plt.show()
#%% md
**Convergence plot:** Compute the running estimate of π after every 100 points (i.e., at n = 100, 200, 300, …, 100,000). Plot this running estimate with a horizontal line at the true π. Add a title and axis labels.
#%%
# Compute the running estimate of π after every 100 points
n_values = np.arange(100, N + 1, 100)
running_pi = []

# Using cumulative sum for efficiency
cumulative_inside = np.cumsum(inside_mask)
running_pi = 4 * cumulative_inside[n_values - 1] / n_values

plt.figure(figsize=(12, 6))
plt.plot(n_values, running_pi, label='Running Estimate')
plt.axhline(y=np.pi, color='r', linestyle='--', label='True π')
plt.xlabel('Number of Points (n)')
plt.ylabel('Estimated π')
plt.title('Convergence of π Estimate via Monte Carlo')
plt.legend()
plt.show()
#%%
# Finding the stabilization point where the estimate stays within ±0.01 of true π
tolerance = 0.01
diffs = np.abs(running_pi - np.pi)
within_tolerance = diffs <= tolerance

# Find the last index where it was OUTSIDE the tolerance to determine when it STAYED inside
outside_indices = np.where(~within_tolerance)[0]
if len(outside_indices) > 0:
    last_outside_idx = outside_indices[-1]
    stabilization_point = n_values[last_outside_idx + 1] if last_outside_idx + 1 < len(n_values) else n_values[-1]
else:
    stabilization_point = n_values[0]

print(f"The estimate stabilizes within ±0.01 of true π at roughly N = {stabilization_point}")

# Evidence check: Show the difference at the stabilization point and thereafter
print(f"Difference at stabilization point: {np.abs(running_pi[np.where(n_values == stabilization_point)[0][0]] - np.pi):.5f}")
#%% md
**Guiding question:** At roughly what sample size does your estimate stabilize within ±0.01 of true π?

Based on the simulation, the estimate stabilizes within ±0.01 of the true value of π at approximately **N = 23100**. Beyond this point, the running estimate consistently remains within the range [3.13159, 3.15159], demonstrating the Law of Large Numbers as the approximation converges with increased sample size.
